# HITTRACK Web — Firebase configuration
# Copy this file to `.env.local` (gitignored) and fill in your project's values.
# To point the app at a different Firebase project (e.g. staging), set these.
# If left unset, the app falls back to the production values baked into src/firebase.js.
#
# These are Firebase WEB config values — they are public by design (not secrets).
# Real security is enforced by firestore.rules, not by hiding these.
#
# Find them in: Firebase Console → Project settings → Your apps → SDK setup and config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
