rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS — any authenticated user can read (for leaderboard, messaging).
    // Owner can edit own doc. Admins have full write. Coaches can update
    // limited fields on member docs (experience, status) for level control
    // and member management — but cannot change roles or delete users.
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;

      // Path A — User edits their own doc, but CANNOT modify membership,
      // role, or status fields. Those are admin-controlled.
      allow update: if request.auth != null
                       && request.auth.uid == userId
                       && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['membership','role','status']);

      // Path B — User can DELETE their own user doc (for account self-deletion)
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Path C — Admin has full write access
      allow update, delete: if request.auth != null
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Path D — Coach can update ONLY experience and status fields on member docs.
      allow update: if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coach'
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['experience', 'status']);
    }

    // WORKOUTS — only owner reads/writes; coach/admin can read; admin can delete (cascade).
    match /workouts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read:        if request.auth != null
                         && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin'];
      allow delete:      if request.auth != null
                         && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // STATS — readable by any authenticated user (for leaderboard);
    // writable by owner. Coach/admin can also update the experience field.
    // Admin can delete (cascade delete).
    match /stats/{userId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == userId;
      // Coach/admin can update only the experience field (level change sync)
      allow update: if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin']
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['experience']);
      allow delete: if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';


      // Inside your existing match /stats/{userId} block:
      match /poseSessions/{sessionId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // CLASSES — anyone authenticated can read; only coach/admin can fully write.
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin'];
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin']
        ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolled'])
          && (
            request.resource.data.enrolled == resource.data.enrolled + 1
            || request.resource.data.enrolled == resource.data.enrolled - 1
          )
        )
      );
    }

    // BOOKINGS — created by the owner; readable by owner and coach/admin.
    match /bookings/{bookingId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read:   if request.auth != null && (
                       resource.data.userId == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin']
                    );
      allow delete: if request.auth != null && (
                       resource.data.userId == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // FEEDBACK — coach creates; member reads their own; admin can do anything.
    match /feedback/{feedbackId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin'];
      // Coach/admin can fully update. The owning member can ONLY toggle
      // the 'hidden' field on their own feedback — they can't edit the
      // coach's actual message content or rating.
      allow update: if request.auth != null && (
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin']
                       || (
                            resource.data.memberId == request.auth.uid
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hidden', 'deletedByMember'])
                          )
                    );
      allow delete: if request.auth != null && (
                       resource.data.memberId == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // MESSAGES — only the participants can read; sender can write own.
    match /messages/{msgId} {
      allow read:   if request.auth != null && (
                       request.auth.uid in resource.data.participants
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
      allow create: if request.auth != null
                       && request.auth.uid in request.resource.data.participants
                       && request.resource.data.from == request.auth.uid;
      allow delete: if request.auth != null && (
                       request.auth.uid in resource.data.participants
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // NOTIFICATIONS — gym announcements + system notifications.
    match /notifications/{notifId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && (
                       request.resource.data.audience != 'coaches'
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
      allow update: if request.auth != null && (
                       resource.data.fromUid == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
      allow delete: if request.auth != null && (
                       resource.data.fromUid == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // ADAPTIVE DECISIONS — owner writes & reads their own; coach/admin can read for analysis.
    match /adaptiveDecisions/{decisionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read:   if request.auth != null && (
                       resource.data.userId == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin']
                    );
      allow delete: if request.auth != null && (
                       resource.data.userId == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // LEVEL CHANGES — coach/admin writes; member can read their own; coach/admin can read all.
    match /levelChanges/{changeId} {
      allow create: if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin'];
      allow read:   if request.auth != null && (
                       resource.data.memberId == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin']
                    );
      allow delete: if request.auth != null && (
                       resource.data.memberId == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // DELETIONS — audit log for permanently deleted users.
    match /deletions/{userId} {
      allow create: if request.auth != null && (
                       request.auth.uid == userId
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
      allow read:   if request.auth != null && (
                       request.auth.uid == userId
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // ACTIVITY — operational event log.
    match /activity/{eventId} {
      allow create: if request.auth != null
                       && request.resource.data.actorId == request.auth.uid;
      allow read:   if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin'];
      allow delete: if request.auth != null && (
                       resource.data.actorId == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin']
                    );
    }

    // ── TRAINING SESSIONS ────────────────────────────────────────────────
    // Created by the member after completing a training session.
    // Member can read their own sessions.
    // Coach and admin can read any session (for member progress review).
    // Admin can delete (for cascade delete on member removal).
    match /trainingSessions/{sessionId} {
      allow create: if request.auth != null
                       && request.resource.data.uid == request.auth.uid;
      allow read:   if request.auth != null && (
                       resource.data.uid == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin']
                    );
      allow delete: if request.auth != null && (
                       resource.data.uid == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // ── TRAINING RECORDINGS ──────────────────────────────────────────────
    // Members submit video recordings of their training sessions to a coach.
    // Read:   the member who submitted it OR the coach it was sent to OR admin.
    // Create: the member themselves (uid must match auth.uid).
    // Update: the assigned coach can mark it as viewed; admin can update anything.
    // Delete: the member OR the assigned coach OR admin.
    match /trainingRecordings/{recordingId} {
      allow read:   if request.auth != null && (
                       resource.data.uid      == request.auth.uid
                       || resource.data.coachUid == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
      allow create: if request.auth != null
                       && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (
                       resource.data.coachUid == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
      allow delete: if request.auth != null && (
                       resource.data.uid      == request.auth.uid
                       || resource.data.coachUid == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }


    // GROUP MESSAGES — Forum chat open to all authenticated users.
    // Anyone can read and post. Only the sender or admin can delete a message.
    match /groupMessages/{msgId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                       && request.resource.data.from == request.auth.uid;
      allow delete: if request.auth != null && (
                       resource.data.from == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // FORUM — community Q&A.
    match /forum/{postId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
                       request.auth.uid == resource.data.authorUid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                       || request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['replies', 'likes', 'likeCount', 'replyCount', 'lastReplyAt', 'answered'])
                    );
      allow delete: if request.auth != null && (
                       request.auth.uid == resource.data.authorUid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
    }

    // PAYMENTS — admin-recorded member payment ledger.
    match /payments/{paymentId} {
      allow read:   if request.auth != null && (
                       resource.data.memberId == request.auth.uid
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
      allow create: if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if false;
      allow delete: if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // DELETED PAYMENTS — soft-delete archive. Tamper-evident, admin-read only.
    match /deletedPayments/{paymentId} {
      allow read:   if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if false;
    }

    // TRIAL USAGE — one-time trial registry. Immutable once written.
    match /trialUsage/{email} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

  }
}
